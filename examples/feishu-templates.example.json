      "route": {
        "target": {
          "id": "oc_your_chat_id_here",
          "type": "chat_id"
        },
        "delivery": {
          "channel": "topic"
        },
        "policy": {
          "lock_target": true,
          "lock_delivery": true
        },
        "thread": {
          "enabled": true,
